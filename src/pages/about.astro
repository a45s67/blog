---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About Fish Yu",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<div class="flex items-center gap-4 mb-6">
			<img
				alt="avatar"
				class="h-20 w-20 rounded-full"
				src="https://files.sakana.tw/blog/Theme/avatar-arona.png"
			/>
			<div>
				<p class="text-lg font-bold">Fish Yu</p>
				<p class="text-muted">我不是檔案玩家 #這個人很懶，什麼都沒寫</p>
			</div>
		</div>
		<p>
			歡迎來到我的部落格，這裡記錄了 CTF、逆向工程、工具與工作流程的各種心得。
		</p>
		<p>
			Find me on <a
				class="cactus-link inline-block"
				href="https://github.com/a45s67"
				rel="noreferrer"
				target="_blank">GitHub</a
			>.
		</p>
	</div>
</PageLayout>
